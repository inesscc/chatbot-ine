
LLM_SERVICE=openrouter

# Ollama Configuration (optional overrides)
#OLLAMA_URL=http://localhost:11434
# OpenRouter Configuration (REQUIRED)
OPENAI_MODEL=qwen/qwen3-32b
OPENAI_API_KEY=<REEMPLAZAR_CON_TU_API_KEY>
OPENAI_API_BASE_URL="https://openrouter.ai/api/v1"


ENABLE_PERSISTENT_CONFIG=True

GLOBAL_LOG_LEVEL=20
# Note: Model selection is done via Valves in Open WebUI interface
# Available models: qwen/qwen3-next-80b-a3b-instruct, deepseek/deepseek-v3.2, openai/gpt-oss-120b